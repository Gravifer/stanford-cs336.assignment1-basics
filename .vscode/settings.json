{
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff", // not moved to astral-sh.ruff quite yet
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },
  "ruff.nativeServer": true,
  "ruff.configurationPreference": "filesystemFirst",
  "mypy-type-checker.args": ["--config-file=pyproject.toml"], // for compatibility with other users
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "workbench.editor.defaultBinaryEditor": "hexEditor.hexedit",
  "workbench.editor.pinnedTabSizing": "shrink",
  "files.exclude": {
    "**/.git": false,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true,
  },
  "explorerExclude.backup": {

  }
}
